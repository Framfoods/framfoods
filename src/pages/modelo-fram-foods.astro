            srcDesktop: "/media/modelo/Insights.webp?width=560",
            srcMobile: "/media/modelo/Insights.webp?width=560",
            alt: "Insights",
            width: 432,
            height: 444,
            loading: "lazy",
            decoding: "async",

            figureClass: "image-card",
            captionClass: "image-card__caption",

            h2: "INSIGHTS",
            h2Class: "image-card__title",

            p: "Identificamos oportunidades reales a partir de data, tendencias y comportamiento del consumidor.",
            pClass: "image-card__text",
            },
            {
            srcDesktop: "/media/modelo/Desarrollo.webp?width=560",

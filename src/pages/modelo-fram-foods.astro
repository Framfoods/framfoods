    <section id="franja-comercial" class="franja-comercial">
    <TextGroupElement
        p="Trabajamos de forma integrada para transformar ideas en soluciones comerciales 
        <span>sólidas,</span>
        <span>alineadas al mercado,</span>
        <span>al canal y</span>
        <span>al consumidor.</span>"
        pId=""
        pClass="franja-comercial__text"
    />
    </section>


<NewsletterForm
  id="newsletter-principal"
  class="newsletter-form banner"

  figureClass="newsletter-form__figure"
  captionClass="newsletter-form__caption"

  contentId=""
  contentClass="newsletter-form__content"

  srcDesktop="/media/newsletter.webp?width=2500"
  srcMobile="/media/newsletter.webp?width=1500"
  alt="Newsletter"
  title="Newsletter"
  width="1920"
  height="250"
  loading="lazy"
  decoding="async"

  h2="Suscríbete a nuestro newsletter"
  h2Id=""
  h2Class="newsletter-form__title"

  p="Recibe actualizaciones, novedades y contenido relevante directamente en tu correo.
  <br>
  Forma parte de nuestra comunidad y entérate primero de lo que viene."
  pId=""
  pClass="newsletter-form__text"

  name="newsletter"
  action="/thankyou"
  method="POST"
  submitMode="native"
  netlify

  successParam="newsletter"
  successValue="ok"
  successMessage="Gracias por suscribirte al newsletter."

  inputWrapperClass="newsletter-form__field"
  inputId="newsletter-email"
  inputClass="newsletter-form__input"
  inputName="email"
  inputDataColumn="Correo electrónico"
  inputPlaceholder="tu correo"
  inputLabel=""
  inputRequired={true}

  buttonClass="newsletter-form__button"
  buttonHtml="Suscribirme al newsletter"
/>



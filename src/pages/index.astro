---
import BaseLayout from "../layouts/BaseLayout.astro";
import TextGroupElement from "../snippets/TextGroupElement.astro";
import ImagenResponsive from "../snippets/ImagenResponsive.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BannerHero from "../components/BannerHero.astro";
import FeatureBlocksSection from "../components/FeatureBlocksSection.astro";
import ImageCardsOverlay from "../components/ImageCardsOverlay.astro";
import ImageCarouselSection from "../components/ImageCarouselSection.astro";
import VideoOverlay from "../components/VideoOverlay.astro";
import ComparisonBannerSection from "../components/ComparisonBannerSection.astro";
import BrandCardsSection from "../components/BrandCardsSection.astro";
import ImageLogoTextBanner from "../components/ImageLogoTextBanner.astro";
import VideoHero from "../components/VideoHero.astro";
import ReviewsCarouselSection  from "../components/ReviewsCarouselSection.astro";
import FormularioLead from "../componentsFormPoliticas/FormularioLead.astro";
import NewsletterForm from "../componentsFormPoliticas/NewsletterForm.astro";


import Formulario from "../components/Formulario.astro";
import { site } from "../data/site";
---

<BaseLayout>
  <Header />

  <main class="container">

<VideoHero
  id="hero-home"
  class="banner"

  srcDesktop="https://static.videezy.com/system/resources/previews/000/018/948/original/ICON-VERSION8_1.mp4"
  srcMobile="https://static.videezy.com/system/resources/previews/000/018/948/original/ICON-VERSION8_1.mp4"

  width="1920"
  height="500"

  autoplay={true}
  muted={true}
  loop={true}
  playsinline={true}
  controls={false}
  preload="auto"

  ariaLabel="Video principal de alimentos"

  h1="Tu socio para construir, escalar y posicionar marcas de alimentos en México"
  h1Class="hero-title"

  linkHtml="Explorar soluciones"
  linkHref="/soluciones"
  linkClass="hero-button"
/>

<BannerHero
  id="bloque-alimentos"
  class="imagen-derecha-texto-izquierda"

  srcDesktop="https://wallpapers.com/images/hd/1920x1080-hd-beach-khfbqt2io95uf0zy.jpg?width=2500"
  srcMobile="https://w0.peakpx.com/wallpaper/791/747/HD-wallpaper-tropical-beach-beach-tropical.jpg?width=1000"
  alt="Alimentos de alta calidad"
  width="682"
  height="378"
  loading="lazy"
  decoding="async"

  p="
  Creamos alimentos de <strong>alta calidad</strong> que combinan <strong>las tendencias</strong> del mercado con una verdadera <strong>conciencia nutricional</strong>

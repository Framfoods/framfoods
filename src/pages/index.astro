        </svg>
    </button>

    <button class="feature-blocks-section__btn next">
        <svg xmlns="http://www.w3.org/2000/svg" width="6" height="11" viewBox="0 0 6 11" fill="none">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M0.292894 9.78123C-0.0976307 9.38772 -0.0976307 8.74972 0.292894 8.35621L3.58579 5.03818L0.292893 1.72014C-0.0976311 1.32664 -0.0976311 0.688636 0.292893 0.29513C0.683417 -0.0983767 1.31658 -0.0983767 1.70711 0.29513L5.70711 4.32567C6.09763 4.71918 6.09763 5.35718 5.70711 5.75068L1.70711 9.78123C1.31658 10.1747 0.683418 10.1747 0.292894 9.78123Z" fill="#EF6A02"/>
        </svg>
    </button>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {

      const slider = document.querySelector('.feature-blocks-section article');

      if (!slider) return;

      const nextBtn = document.querySelector('.feature-blocks-section__btn.next');
      const prevBtn = document.querySelector('.feature-blocks-section__btn.prev');

      const getCardWidth = () => {
          return (
              slider.querySelector('.feature-blocks-section__item').offsetWidth + 24
          );
      };

      nextBtn?.addEventListener('click', () => {
          slider.scrollBy({
              left: getCardWidth(),
              behavior: 'smooth',
          });
      });

      prevBtn?.addEventListener('click', () => {
          slider.scrollBy({
              left: -getCardWidth(),
              behavior: 'smooth',
          });
      });

  });
</script>


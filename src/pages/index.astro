<script>
document.addEventListener("DOMContentLoaded", () => {

  const banners = [
    {
      srcDesktop: "https://wallpapers.com/images/hd/1920x1080-hd-beach-khfbqt2io95uf0zy.jpg?width=2500",
      srcMobile: "https://w0.peakpx.com/wallpaper/791/747/HD-wallpaper-tropical-beach-beach-tropical.jpg?width=1000",
      alt: "INSIGHTS",
      title: "INSIGHTS",
      text: "Identificamos oportunidades reales a partir de data, tendencias y comportamiento del consumidor."
    },
    {
      srcDesktop: "https://wallpapers.com/images/hd/lakeside-car-full-desktop-screen-hd-ffduevjvagzqhrhy.jpg",
      srcMobile: "https://wallpapers.com/images/hd/lakeside-car-full-desktop-screen-hd-ffduevjvagzqhrhy.jpg",
      alt: "DESARROLLO",
      title: "DESARROLLO",
      text: "Transformamos insights en productos viables, diferenciados y listos para competir."
    },
    {
      srcDesktop: "https://www.pixelstalk.net/wp-content/uploads/wallpapers/Landscape-Wallpapers-Full-HD.jpg",
      srcMobile: "https://www.pixelstalk.net/wp-content/uploads/wallpapers/Landscape-Wallpapers-Full-HD.jpg",
      alt: "PRODUCCIÓN",
      title: "PRODUCCIÓN",
      text: "Escalamos con eficiencia, calidad y consistencia en cada etapa del proceso."
    },
    {
      srcDesktop: "https://wallpaperaccess.com/full/138728.jpg",
      srcMobile: "https://wallpaperaccess.com/full/138728.jpg",
      alt: "DISTRIBUCIÓN",
      title: "DISTRIBUCIÓN",
      text: "Llevamos el producto a los canales correctos, optimizando tiempos y cobertura."
    },
    {
      srcDesktop: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSTDaHcXhDzgOWMkolpXKkCu-oRFAznaY4lOQ&s",
      srcMobile: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSTDaHcXhDzgOWMkolpXKkCu-oRFAznaY4lOQ&s",
      alt: "RETAIL",
      title: "RETAIL",
      text: "Ejecutamos estrategias en punto de venta que maximizan visibilidad y rotación."
    },
    {
      srcDesktop: "https://i.imgur.com/idDZITt.jpg",
      srcMobile: "https://i.imgur.com/idDZITt.jpg",
      alt: "CONSUMIDOR",
      title: "CONSUMIDOR",
      text: "Generamos conexión, adopción y recompra a través de propuestas relevantes."
    }
  ];

  const banner = document.getElementById("banner-insights");

  const sourceDesktop = banner.querySelector('source[media="(min-width: 768px)"]');
  const sourceMobile = banner.querySelector('source[media="(max-width: 767px)"]');
  const img = banner.querySelector("img");
  const title = banner.querySelector("h2");
  const text = banner.querySelector("p");

  let index = 0;

  function updateBanner() {
    const item = banners[index];

    sourceDesktop.srcset = item.srcDesktop;
    sourceMobile.srcset = item.srcMobile;

    img.src = item.srcMobile;
    img.alt = item.alt;
    img.title = item.alt;

    title.textContent = item.title;
    text.textContent = item.text;

    index = (index + 1) % banners.length;
  }

  setInterval(updateBanner, 6000);

});
</script>





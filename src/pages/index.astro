<script>
  document.addEventListener("DOMContentLoaded", () => {

    const PORTO57 = document.querySelector("#PORTO57 img");
    const LATITUDE45 = document.querySelector("#LATITUDE45 img");
    const Camanchaca = document.querySelector("#Camanchaca img");
    const SIWIN = document.querySelector("#SIWIN img");
    const OsoleMio = document.querySelector("#OsoleMio img");
    const NaturalOne = document.querySelector("#NaturalOne img");
    const MARINA = document.querySelector("#MARINA img");
    const FORNODEMINAS = document.querySelector("#FORNODEMINAS img");
    const LaMenorquina = document.querySelector("#LaMenorquina img");
    const alo = document.querySelector("#alo img");
    const RUSSETHOUSE = document.querySelector("#RUSSETHOUSE img");

    const changeImage = (img, newSrc) => {
      if (!img) return;

      const picture = img.closest("picture");
      const sources = picture ? picture.querySelectorAll("source") : [];

      const original = img.currentSrc || img.src;

      img.parentElement.parentElement.addEventListener("mouseenter", () => {
        img.src = newSrc;
        sources.forEach(s => s.srcset = newSrc);
      });

      img.parentElement.parentElement.addEventListener("mouseleave", () => {
        img.src = original;
        sources.forEach((s, i) => s.srcset = original);
      });
    };

    changeImage(PORTO57, "/media/partners-hover/hover-porto57.webp?width=1500");
    changeImage(LATITUDE45, "/media/partners-hover/hover-latitude45.webp?width=1500");
    changeImage(Camanchaca, "/media/partners-hover/hover-camanchaca.webp?width=1500");
    changeImage(SIWIN, "/media/partners-hover/hover-siwin.webp?width=1500");
    changeImage(OsoleMio, "/media/partners-hover/hover-osolemio.webp?width=1500");
    changeImage(NaturalOne, "/media/partners-hover/hover-naturalone.webp?width=1500");
    changeImage(MARINA, "/media/partners-hover/hover-marina.webp?width=1500");
    changeImage(FORNODEMINAS, "/media/partners-hover/hover-fornodeminas.webp?width=1500");
    changeImage(LaMenorquina, "/media/partners-hover/hover-lamenorquina.webp?width=1500");
    changeImage(alo, "/media/partners-hover/hover-alo.webp?width=1500");
    changeImage(RUSSETHOUSE, "/media/partners-hover/hover-russethouse.webp?width=1500");

    const cards = document.querySelectorAll(".brand-cards-section__card");

    cards.forEach((card) => {
      const image = card.querySelector("img");

      if (!image) return;

      image.addEventListener("click", () => {
        card.classList.toggle("is-active");
      });
    });

  });
</script>


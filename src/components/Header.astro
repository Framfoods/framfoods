---
import { logoHeader, componentes, navAriaLabel } from "../data/header";
---
<header class="site-header">
  <a href="/" title={logoHeader.title}>
    <img
      src={`${logoHeader.logo}?width=${logoHeader.resolucion}`}
      alt={logoHeader.alt}
      title={logoHeader.title}
      width={logoHeader.ancho}
      height={logoHeader.alto}
      decoding="async"
    />
  </a>
  <details class="mobile-nav">
    <summary class="mobile-nav__toggle">
      <a role="button" class="icon-menu" aria-hidden="true" title={navAriaLabel.abrir}>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="13" viewBox="0 0 14 13" fill="none">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M0 1.00763C0 0.451133 0.447715 0 1 0H13C13.5523 0 14 0.451133 14 1.00763C14 1.56413 13.5523 2.01527 13 2.01527H1C0.447715 2.01527 0 1.56413 0 1.00763Z" fill="#0A0A0A"/>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M0 6.0458C0 5.4893 0.447715 5.03817 1 5.03817H13C13.5523 5.03817 14 5.4893 14 6.0458C14 6.60231 13.5523 7.05344 13 7.05344H1C0.447715 7.05344 0 6.60231 0 6.0458Z" fill="#0A0A0A"/>
          <path fill-rule="evenodd" clip-rule="evenodd" d="M0 11.084C0 10.5275 0.447715 10.0763 1 10.0763H13C13.5523 10.0763 14 10.5275 14 11.084C14 11.6405 13.5523 12.0916 13 12.0916H1C0.447715 12.0916 0 11.6405 0 11.084Z" fill="#0A0A0A"/>
        </svg>
      </a>
      <a role="button" class="icon-close" aria-hidden="true" title={navAriaLabel.cerrar}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M4.29289 4.29289C4.68342 3.90237 5.31658 3.90237 5.70711 4.29289L10 8.58579L14.2929 4.29289C14.6834 3.90237 15.3166 3.90237 15.7071 4.29289C16.0976 4.68342 16.0976 5.31658 15.7071 5.70711L11.4142 10L15.7071 14.2929C16.0976 14.6834 16.0976 15.3166 15.7071 15.7071C15.3166 16.0976 14.6834 16.0976 14.2929 15.7071L10 11.4142L5.70711 15.7071C5.31658 16.0976 4.68342 16.0976 4.29289 15.7071C3.90237 15.3166 3.90237 14.6834 4.29289 14.2929L8.58579 10L4.29289 5.70711C3.90237 5.31658 3.90237 4.68342 4.29289 4.29289Z" fill="#0A0A0A"/>
        </svg>
      </a>
    </summary>
    <nav class="mobile-nav__menu" aria-label={navAriaLabel.titulo}>
      <h2>
        MENU
      </h2>
      <ul>
        {componentes.map((link) => (
          !link.primary && (
            <li>
              <a
                href={link.href}
                class="nav-link"
                title={link.label}
              >
                {link.label}
              </a>
            </li>
          )
        ))}
      </ul>
    </nav>
  </details>

  <nav class="desktop-nav" aria-label={navAriaLabel.titulo}>
    <ul>
      {componentes.map((link) => (
        !link.primary && (
          <li>
            <a
              href={link.href}
              class="nav-link"
            >
              {link.label}
            </a>
          </li>
        )
      ))}
    </ul>
  </nav>
  {componentes.map((link) => (
    link.primary && (
      <a href={link.href} class={link.primary ? "btn" : "nav-link"}>
        {link.label}
      </a>
    )
  ))}
</header>

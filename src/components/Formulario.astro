---
import { preguntas, boton } from "../data/formulario";
---

<section id="formulario" class="section">
  <h2>Formulario</h2>

<form
    name="contacto"
    method="POST"
    action={boton[0].paginaGracias}
    data-netlify="true"
    netlify-honeypot="bot-field"
  >
    <input
      type="hidden"
      name="form-name"
      value="contacto"
    />

    <p hidden>
      <label>
        No llenar:
        <input name="bot-field" />
      </label>
    </p>
    <article class="preguntas">

  {/* 🔼 GRUPO SUPERIOR */}
  <div class="grupo-arriba">
    {preguntas
      .filter(item => item.etiqueta === "input" || item.etiqueta === "option")
      .map((item, index) => (
        <div class="grupo-input">

          <label for={`campo-${index}`}>
            {item.label}
          </label>

          {item.etiqueta === "input" && (
            <input
              id={`campo-${index}`}
              type={item.tipo}
              placeholder={item.placeholder}
              required={item.requerido}
            />
          )}

            {item.etiqueta === "option" && (
            <select id={`campo-${index}`} required={item.requerido}>
                {item.opciones.map((opt, i) => (
                <option
                    value={opt.valor}
                    disabled={i === 0}
                    selected={i === 0}
                    hidden={i === 0}
                >
                    {opt.opcion}
                </option>
                ))}
            </select>
            )}

        </div>
    ))}
  </div>

  {/* 🔽 GRUPO INFERIOR */}
  <div class="grupo-abajo">
    {preguntas
      .filter(item => item.etiqueta === "textarea" || item.etiqueta === "checkbox")
      .map((item, index) => (
        <div class="grupo-input">

          {/* TEXTAREA */}
          {item.etiqueta === "textarea" && (
            <>
              <label for={`campo-${index}`}>
                {item.label}
              </label>
              <textarea
                id={`campo-${index}`}
                placeholder={item.placeholder}
                required={item.requerido}
              ></textarea>
            </>
          )}

          {/* CHECKBOX */}
          {item.etiqueta === "checkbox" && (
            <label class="checkbox">
              <input type="checkbox" required={item.requerido} />
              <small>{item.label}{" "}</small>
                <button 
                type="button" 
                class="aceptar-terminos"
                data-url={item.urlPolíticas}
                >
                <small>{item.textoPolitica}</small>
                </button>
            </label>
          )}

        </div>
    ))}
  </div>

<div id="modal-terminos" class="modal-terminos">
  <div class="modal-contenido-terminos">
    
    <button class="cerrar">✕</button>

    <iframe 
      id="iframe-terminos"
      src=""
      width="100%" 
      height="400"
      style="border:none;"
    ></iframe>

  </div>
</div>

</article>

    {/* BOTÓN */}
    <button type="submit" class="enviar">
        {boton[0].cta} 
        <i class="fa-solid fa-paper-plane"></i>
    </button>

  </form>
</section>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("modal-terminos");
    const iframe = document.getElementById("iframe-terminos");

    document.addEventListener("click", (e) => {
      const btn = e.target.closest(".aceptar-terminos");

      if (btn) {
        iframe.src = btn.dataset.url;
        modal.style.display = "flex";
      }

      if (e.target.closest(".cerrar") || e.target === modal) {
        modal.style.display = "none";
        iframe.src = "";
      }
    });
  });
</script>
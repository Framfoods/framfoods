---
import TextGroupElement from "../snippets/TextGroupElement.astro";
import ImagenResponsive from "../snippets/ImagenResponsive.astro";

const {
  id = "",
  class: clase = "",

  h1,
  h1Id,
  h1Class,

  h2,
  h2Id,
  h2Class,

  h3,
  h3Id,
  h3Class,

  p,
  pId,
  pClass,

  linkHtml,
  linkHref,
  linkId,
  linkClass,
  linkTitle,
  linkAriaLabel,
  linkTarget,
  linkRel,

  articleGap = "42px",

  // velocidad
  speedDesktop = "0.4",
  speedMobile = "0.8",

  items = [],
} = Astro.props;

const tieneTexto = h1 || h2 || h3 || p || linkHtml;
const sectionSelector = id ? `#${id}` : "";
const articleStyle = articleGap ? `gap:${articleGap};` : "";
---

<section
  {...(id ? { id } : {})}
  {...(clase ? { class: clase } : {})}
  data-image-carousel
>

  {tieneTexto && (
    <TextGroupElement
      h1={h1}
      h1Id={h1Id}
      h1Class={h1Class}

      h2={h2}
      h2Id={h2Id}
      h2Class={h2Class}

      h3={h3}
      h3Id={h3Id}
      h3Class={h3Class}

      p={p}
      pId={pId}
      pClass={pClass}

      linkHtml={linkHtml}
      linkHref={linkHref}
      linkId={linkId}
      linkClass={linkClass}
      linkTitle={linkTitle}
      linkAriaLabel={linkAriaLabel}
      linkTarget={linkTarget}
      linkRel={linkRel}
    />
  )}

  <article
    data-carousel-track
    style={articleStyle}
  >
    {items.map((item) => (
      <ImagenResponsive
        srcDesktop={item.srcDesktop}
        srcMobile={item.srcMobile}
        alt={item.alt}
        title={item.title}
        width={item.width}
        height={item.height}
        priority={item.priority}
        loading={item.loading}
        decoding={item.decoding}
      />
    ))}
  </article>

</section>
<script define:vars={{
  sectionSelector,
  speedDesktop,
  speedMobile
}}>
  document.addEventListener("DOMContentLoaded", () => {

    const carousel =
      document.querySelector(sectionSelector);

    if (!carousel) return;

    if (carousel.dataset.initialized === "true") return;

    carousel.dataset.initialized = "true";

    const track =
      carousel.querySelector("[data-carousel-track]");

    if (!track) return;

    const isDesktop =
      window.innerWidth > 1024;

    const speed =
      isDesktop
        ? Number(speedDesktop)
        : Number(speedMobile);

    // estilos forzados
    track.style.display = "flex";
    track.style.flexWrap = "nowrap";
    track.style.overflowX = "hidden";
    track.style.scrollBehavior = "auto";

    // duplicar logos
    const originals =
      Array.from(track.children);

    originals.forEach((item) => {

      const clone = item.cloneNode(true);

      clone.setAttribute(
        "aria-hidden",
        "true"
      );

      track.appendChild(clone);

    });

    let paused = false;

    // AQUÍ la diferencia importante
    let currentScroll = 0;

    const animate = () => {

      if (!paused) {

        currentScroll += speed;

        const resetPoint =
          track.scrollWidth / 2;

        if (currentScroll >= resetPoint) {
          currentScroll = 0;
        }

        track.scrollLeft = currentScroll;

      }

      requestAnimationFrame(animate);

    };

    // desktop hover
    carousel.addEventListener(
      "mouseenter",
      () => {

        if (isDesktop) {
          paused = true;
        }

      }
    );

    carousel.addEventListener(
      "mouseleave",
      () => {

        if (isDesktop) {
          paused = false;
        }

      }
    );

    // mobile touch
    carousel.addEventListener(
      "touchstart",
      () => {
        paused = true;
      },
      { passive: true }
    );

    carousel.addEventListener(
      "touchend",
      () => {
        paused = false;
      },
      { passive: true }
    );

    requestAnimationFrame(animate);

  });
</script>
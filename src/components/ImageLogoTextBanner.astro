---
// src/components/ImageLogoTextBanner.astro

import ImagenResponsive from "../snippets/ImagenResponsive.astro";
import TextGroupElement from "../snippets/TextGroupElement.astro";

const {
  id = "",
  class: clase = "",

  // Imagen principal
  srcDesktop,
  srcMobile,
  alt,
  title,
  width,
  height,
  priority,
  loading,
  decoding,

  // Imagen secundaria / logo dentro del figcaption
  logoSrcDesktop,
  logoSrcMobile,
  logoAlt,
  logoTitle,
  logoWidth,
  logoHeight,
  logoPriority,
  logoLoading,
  logoDecoding,

  h1,
  h1Id,
  h1Class,

  h2,
  h2Id,
  h2Class,

  h3,
  h3Id,
  h3Class,

  p,
  pId,
  pClass,

  linkHtml,
  linkHref,
  linkId,
  linkClass,
  linkTitle,
  linkAriaLabel,
  linkTarget,
  linkRel,
} = Astro.props;

const tieneLogo = logoSrcDesktop || logoSrcMobile;
const tieneTexto = h1 || h2 || h3 || p || linkHtml;
---

<section
  {...(id ? { id } : {})}
  {...(clase ? { class: clase } : {})}
>
  <figure>
    <ImagenResponsive
      srcDesktop={srcDesktop}
      srcMobile={srcMobile}
      alt={alt}
      title={title}
      width={width}
      height={height}
      priority={priority}
      loading={loading}
      decoding={decoding}
    />

    {(tieneLogo || tieneTexto) && (
      <figcaption>
        {tieneLogo && (
          <ImagenResponsive
            srcDesktop={logoSrcDesktop}
            srcMobile={logoSrcMobile}
            alt={logoAlt}
            title={logoTitle}
            width={logoWidth}
            height={logoHeight}
            priority={logoPriority}
            loading={logoLoading}
            decoding={logoDecoding}
          />
        )}

        {tieneTexto && (
          <TextGroupElement
            h1={h1}
            h1Id={h1Id}
            h1Class={h1Class}

            h2={h2}
            h2Id={h2Id}
            h2Class={h2Class}

            h3={h3}
            h3Id={h3Id}
            h3Class={h3Class}

            p={p}
            pId={pId}
            pClass={pClass}

            linkHtml={linkHtml}
            linkHref={linkHref}
            linkId={linkId}
            linkClass={linkClass}
            linkTitle={linkTitle}
            linkAriaLabel={linkAriaLabel}
            linkTarget={linkTarget}
            linkRel={linkRel}
          />
        )}
      </figcaption>
    )}
  </figure>
</section>